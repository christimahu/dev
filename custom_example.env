# Development Environment Example Configuration
# Copy this file to custom.env and modify as needed
# The custom.env file will be read by dev.py but won't be committed to git

# Port mappings (host:container format)
# Format: PORT_NAME=host_port:container_port
PORT_HTTP=9000:8000
PORT_DEV=9097:8097
PORT_API=9098:8098
PORT_WEBSOCKET=9099:8099
PORT_VITE=5274:5173

# Additional ports (add as needed)
PORT_DB=5432:5432
PORT_REDIS=6379:6379

# Container resources
# Uncomment to set resource limits
# MEMORY_LIMIT=4g
# CPU_LIMIT=2

# Environment variables for development
NODE_ENV=development
PYTHONUNBUFFERED=1
DEBUG=true

# Project specific settings
# Add your custom environment variables below
