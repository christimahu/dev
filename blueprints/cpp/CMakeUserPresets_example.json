{
  "version": 3,
  "include": ["CMakePresets.json"],
  "configurePresets": [
    {
      "name": "chatbot-debug",
      "inherits": "debug",
      "displayName": "Chatbot (Debug)",
      "cacheVariables": {
        "PROJECT_NAME": "chatbot",
        "PROJECT_DISPLAY_NAME": "Chatbot",
        "PROJECT_PREFIX": "chatbot",
        "PROJECT_DESCRIPTION": "Chatbot"
      }
    },
    {
      "name": "chatbot-release",
      "inherits": "release",
      "displayName": "chatbot (Release)",
      "cacheVariables": {
        "PROJECT_NAME": "chatbot",
        "PROJECT_DISPLAY_NAME": "Chatbot",
        "PROJECT_PREFIX": "chatbot",
        "PROJECT_DESCRIPTION": "Chatbot"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "chatbot-debug",
      "configurePreset": "chatbot-debug"
    },
    {
      "name": "chatbot-release",
      "configurePreset": "chatbot-release"
    }
  ],
  "testPresets": [
    {
      "name": "chatbot",
      "configurePreset": "chatbot-debug"
    }
  ]
}
