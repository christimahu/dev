# ==========================================================================
# Development Environment Configuration (Example)
# ==========================================================================
# 
# This file serves as a template for your custom environment settings.
# To use it:
#   1. Copy this file: cp dev_example.env dev.env
#   2. Customize the settings according to your needs
#   3. Run 'dev build' to create your container with these settings
#
# This file controls:
#   - Directory mappings between host and container
#   - Default working directory
#   - Port mappings for development services
#   - Environment variables passed to the container
# ==========================================================================

# ==========================================================================
# DIRECTORY MAPPINGS
# ==========================================================================
# Format: MOUNT=HOST_PATH:CONTAINER_PATH[:OPTIONS]
# 
# HOST_PATH:      Path on your local machine (use ~ for home directory)
# CONTAINER_PATH: Where it appears inside the container
# OPTIONS:        Optional mount options (e.g., ro for read-only)
#
# IMPORTANT: 
# - Each mapping must be on its own line
# - Use ~/.dev instead of ~/dev to match the hidden directory convention
# - Each host directory MUST exist before running 'dev build'
# - Always mount your code directory to access your projects
# ==========================================================================

# Essential mappings - these should always be included
MOUNT=~/.dev:/home/me/.dev
MOUNT=~/code:/home/me/code
MOUNT=~/.ssh:/home/me/.ssh:ro
MOUNT=~/.gitconfig:/home/me/.gitconfig:ro

# Optional mappings - uncomment as needed
# MOUNT=~/Documents:/home/me/Documents
# MOUNT=~/Downloads:/home/me/Downloads
# MOUNT=~/Pictures:/home/me/Pictures

# ==========================================================================
# DEFAULT WORKING DIRECTORY
# ==========================================================================
# This is the directory the container will start in when you run 'dev'
# Must be an absolute path inside the container
# Should usually point to your main code/projects directory
# ==========================================================================

DEFAULT_WORKDIR=/home/me/code

# ==========================================================================
# PORT MAPPINGS
# ==========================================================================
# Format: PORT=HOST_PORT:CONTAINER_PORT
#
# Maps ports from inside the container to your host machine so you can
# access services running in the container from your local browser.
# 
# Each port mapping must be on its own line.
# Comments must be on separate lines (not inline with port mappings).
# ==========================================================================

# HTTP/Web server
PORT=9000:8000

# Development server 
PORT=9097:8097

# API server
PORT=9098:8098

# WebSocket server
PORT=9099:8099

# Frontend development (Vite, etc.)
PORT=5274:5173

# Additional service ports (uncomment as needed)
# PORT=5432:5432  # PostgreSQL
# PORT=6379:6379  # Redis
# PORT=27017:27017  # MongoDB
# PORT=3306:3306  # MySQL/MariaDB
# PORT=9090:9090  # Prometheus

# ==========================================================================
# ENVIRONMENT VARIABLES
# ==========================================================================
# These variables will be available inside the container
# Useful for setting development flags, API keys, etc.
# ==========================================================================

# Development flags
NODE_ENV=development
PYTHONUNBUFFERED=1
DEBUG=true

# Build flags (uncomment as needed)
# LDFLAGS=-L/usr/local/lib
# CPPFLAGS=-I/usr/local/include
# GOPATH=/home/me/go

# Project-specific settings (add your own as needed)
# API_KEY=development_key_only
# DATABASE_URL=postgres://user:pass@localhost:5432/dbname
# AWS_PROFILE=development
# GOOGLE_APPLICATION_CREDENTIALS=/home/me/.config/gcloud/application_default_credentials.json

# ==========================================================================
# CONTAINER RESOURCES
# ==========================================================================
# Control how much system resources the container can use
# Uncomment and adjust as needed
# ==========================================================================

# MEMORY_LIMIT=4g  # Memory limit (4GB)
# CPU_LIMIT=2      # Limit to 2 CPU cores
